      "once": true
    },
    "choices": [
      {
        "text": "拿过她的电话说"这里交给我，你先去喝口水"",
        "affection_delta": {"lin": 4},
        "set_flags": ["lin_ch4_trust"],
        "mark_visited": true,
        "result_text": "她第一次没有拒绝。你处理完电话回头看她，她正低着头，肩膀在微微颤抖。",
        "advance_time": true
      },
      {
        "text": "默默开始帮忙搬运正确的物资",
        "affection_delta": {"lin": 3},
        "set_flags": ["lin_ch4_silent_help"],
        "mark_visited": true,
        "result_text": "她挂了电话后发现物资已经被你搬好了一半，嘴唇动了动，最后只说了句"……笨蛋"。",
        "advance_time": true
      }
    ]
  },
  {
    "id": "evt_lin_ch4_2",
    "point_id": "track_side",
    "time_slot": "night",
    "chapter": 4,
    "act": "破冰",
    "route": "lin",
    "day_range": [19, 24],
    "speaker": "林澄",
    "text": "文化祭尾声，操场上放起了烟花。人群里你看到林澄一个人站在看台最高处。走近后发现她眼眶是红的。烟花在她的镜片上一明一灭。",
    "conditions": {
      "required_flags": ["lin_ch4_trust"],
      "blocked_flags": ["lin_ch4_confession", "lin_ch4_stay"],
      "affection_at_least": {"lin": 12},
      "once": true
    },
    "choices": [
      {
        "text": "什么都不说，在她旁边坐下",
        "affection_delta": {"lin": 4},
        "set_flags": ["lin_ch4_confession"],
        "mark_visited": true,
        "unlock_cg": "cg_fireworks",
        "result_text": "很久之后她终于小声说了："……其实有时候，我也想有人帮我。"烟花在身后绽放，她的泪终于落了下来。",
        "advance_time": false
      },
      {
        "text": "问她还好吗",
        "affection_delta": {"lin": 2},
        "set_flags": ["lin_ch4_stay"],
        "mark_visited": true,
        "result_text": "她说"嗯，没事"。但没有走开。你们就这样并肩站着，直到烟花全部放完。",
        "advance_time": false
      }
    ]
  },
  {
    "id": "evt_lin_ch5_good",
    "point_id": "rooftop",
    "time_slot": "night",
    "chapter": 5,
    "act": "定格",
    "route": "lin",
    "day_range": [24, 28],
    "speaker": "林澄",
    "text": "初冬的天台很冷。林澄第一次主动给你发了消息——"你能来天台一趟吗"。她背对着你站在栏杆旁，声音很轻："苏逸学长毕业了，姐姐出国了，我一直觉得靠自己就够了。但是……"她转过身，路灯下能看到她眼角有泪光。",
    "conditions": {
      "required_flags": ["lin_ch4_confession"],
      "blocked_flags": ["lin_ending_true", "lin_ending_warm"],
      "affection_at_least": {"lin": 15},
      "once": true
    },
    "choices": [
      {
        "text": "走上前握住她的手，说"以后你不用一个人了"",
        "affection_delta": {"lin": 5},
        "set_flags": ["lin_ending_true"],
        "mark_visited": true,
        "unlock_cg": "cg_lin_rooftop_true",
        "result_text": "她的手冰凉的，但紧紧回握了你。泪顺着脸颊滑下来，嘴角却弯了。"你啊……"她哭着笑了，"明明我说了不用担心的。"夜空下，两个人的影子终于重叠在一起。",
        "advance_time": false
      },
      {
        "text": "把围巾解下来围在她脖子上",
        "affection_delta": {"lin": 3},
        "set_flags": ["lin_ending_warm"],
        "mark_visited": true,
        "unlock_cg": "cg_lin_rooftop_warm",
        "result_text": "她低下头，手指攥住围巾的一端。风很大，但谁都没有走开。"下学期……你还会来帮忙吧？"她的声音被风吹散了一半。",
        "advance_time": false
      }
    ]
  },
  {
