  {
    "id": "evt_yuki_ch1_1",
    "point_id": "teaching_front",
    "time_slot": "after_school",
    "chapter": 1,
    "act": "偶遇",
    "route": "yuki",
    "day_range": [1, 3],
    "speaker": "雪纪",
    "text": "放学后的教学楼前，你被一阵"咔嚓"声吸引。一个银灰长发的女生正半蹲着，把相机镜头对准了西沉的太阳。发现你靠近后，她毫不犹豫地把镜头转向了你。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["yuki_ch1_posed", "yuki_ch1_blocked"],
      "affection_at_least": {},
      "once": true
    },
    "choices": [
      {
        "text": "配合她的镜头，摆个自然的姿势",
        "affection_delta": {"yuki": 3},
        "set_flags": ["yuki_ch1_posed"],
        "mark_visited": true,
        "result_text": "她放下相机时嘴角翘了一下——很快又恢复了面无表情。"不错，光刚好。"她低声说，更像是在自言自语。",
        "advance_time": false
      },
      {
