[
  {
    "id": "evt_lin_ch1_1",
    "point_id": "school_gate",
    "time_slot": "morning",
    "chapter": 1,
    "act": "偶遇",
    "route": "lin",
    "day_range": [1, 3],
    "speaker": "林澄",
    "text": "你第一天到校，校门口的风突然大了起来。林澄抱着一摞活动文件被吹得手忙脚乱，几张纸飞了出去。她皱着眉快步去追，始终没有开口找人帮忙。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch1_helped", "lin_ch1_greeted"],
      "affection_at_least": {},
      "once": true
    },
    "choices": [
      {
        "text": "追上去帮她捡回飞走的文件",
        "affection_delta": {"lin": 3},
        "set_flags": ["lin_ch1_helped"],
        "mark_visited": true,
        "result_text": "她愣了一下，然后认真地说了句"谢谢"。你注意到她左手腕上那只简洁的银色手表在阳光下闪了一下。",
        "advance_time": true
      },
      {
        "text": "站在原地提醒她有张纸飞到身后了",
        "affection_delta": {"lin": 1},
        "set_flags": ["lin_ch1_greeted"],
        "mark_visited": true,
        "result_text": "她点点头，自己去捡了回来。经过你身边时，礼貌地说了声"谢谢提醒"。",
        "advance_time": true
      }
    ]
  },
  {
    "id": "evt_lin_ch1_2",
    "point_id": "club_building",
    "time_slot": "after_school",
    "chapter": 1,
    "act": "偶遇",
    "route": "lin",
    "day_range": [1, 4],
    "speaker": "林澄",
    "text": "班主任建议你加入一个社团融入校园生活，你来到社团楼。学生会的门开着，林澄一个人在整理一面巨大的活动公告板。你敲了敲门框。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch1_visited", "lin_ch1_pin"],
      "affection_at_least": {},
      "once": true
    },
    "choices": [
      {
        "text": "说你是新转来的，想了解学生会",
        "affection_delta": {"lin": 2},
        "set_flags": ["lin_ch1_visited"],
        "mark_visited": true,
        "result_text": "她简短但认真地介绍了学生会的工作。你发现她说到活动筹备时眼睛会微微发亮。",
        "advance_time": false
      },
      {
        "text": "帮她把掉下来的图钉递过去",
        "affection_delta": {"lin": 2},
        "set_flags": ["lin_ch1_pin"],
        "mark_visited": true,
        "result_text": "她终于停下来看了你一眼，说了句"你是那个新转来的？"语气里有一点意外的柔软。",
        "advance_time": false
      }
    ]
  },
  {
    "id": "evt_lin_ch2_1",
    "point_id": "club_building",
    "time_slot": "after_school",
    "chapter": 2,
    "act": "靠近",
    "route": "lin",
    "day_range": [4, 7],
    "speaker": "林澄",
    "text": "文化祭将至，学生会忙得不可开交。你看到林澄独自搬着几箱布展材料上楼梯，明显有些吃力。额头上渗着细密的汗珠，但她一声不吭。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch2_carry", "lin_ch2_ask"],
      "affection_at_least": {},
      "flag_any": ["lin_ch1_visited", "lin_ch1_helped", "lin_ch1_pin", "lin_ch1_greeted"],
      "once": true
    },
    "choices": [
      {
        "text": "直接过去扛起最重的那箱",
        "affection_delta": {"lin": 3},
        "set_flags": ["lin_ch2_carry"],
        "mark_visited": true,
        "result_text": "她犹豫了一下，小声说了句"……谢谢"。你注意到她的手指因为搬了太久而发红。",
        "advance_time": true
      },
      {
        "text": "问她要不要找其他人帮忙",
        "affection_delta": {"lin": 1},
        "set_flags": ["lin_ch2_ask"],
        "mark_visited": true,
        "result_text": "她摇头说"马上就好了"，然后咬着牙又搬起一箱。",
        "advance_time": true
      }
    ]
  },
  {
    "id": "evt_lin_ch2_2",
    "point_id": "rooftop",
    "time_slot": "after_school",
    "chapter": 2,
    "act": "靠近",
    "route": "lin",
    "day_range": [5, 9],
    "speaker": "林澄",
    "text": "你发现天台上有人——林澄坐在角落，面前放着一个便当盒。她看到你时明显慌了一下，把便当盒往身后藏了藏。银框眼镜后面的眼神有些躲闪。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch2_cake_secret", "lin_ch2_cake_miss"],
      "affection_at_least": {"lin": 3},
      "once": true
    },
    "choices": [
      {
        "text": "假装没看到，在旁边坐下看风景",
        "affection_delta": {"lin": 3},
        "set_flags": ["lin_ch2_cake_secret"],
        "mark_visited": true,
        "result_text": "过了一会儿她主动把便当盒拿出来——里面是一块草莓蛋糕。"别跟别人说。"她小声说，脸红到耳根。",
        "advance_time": false
      },
      {
        "text": "好奇地问她在吃什么",
        "affection_delta": {"lin": 1},
        "set_flags": ["lin_ch2_cake_miss"],
        "mark_visited": true,
        "result_text": "她红着脸说"没什么"，把盒子收了起来。你总觉得闻到了草莓的甜香。",
        "advance_time": false
      }
    ]
  },
  {
    "id": "evt_lin_ch2_3",
    "point_id": "track_side",
    "time_slot": "night",
    "chapter": 2,
    "act": "靠近",
    "route": "lin",
    "day_range": [7, 11],
    "speaker": "林澄",
    "text": "天色已暗，操场边只剩路灯。林澄抱着一摞签到表从社团楼方向走过来，脚步有些疲惫。她没注意到你。路灯把她的影子拉得很长。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch2_walk_together", "lin_ch2_noticed"],
      "affection_at_least": {"lin": 5},
      "flag_any": ["lin_ch2_carry"],
      "once": true
    },
    "choices": [
      {
        "text": "走上去说"我送你到校门口吧"",
        "affection_delta": {"lin": 3},
        "set_flags": ["lin_ch2_walk_together"],
        "mark_visited": true,
        "result_text": "她想拒绝，嘴唇动了动，但终于说了句"……那就麻烦你了"。一路上她走得比平时慢了很多。",
        "advance_time": true
      },
      {
        "text": "远远跟着确认她安全出校门",
        "affection_delta": {"lin": 2},
        "set_flags": ["lin_ch2_noticed"],
        "mark_visited": true,
        "result_text": "第二天早上她叫住你："昨晚……好像看到你了。"语气里分不清是质问还是感谢。",
        "advance_time": true
      }
    ]
  },
  {
    "id": "evt_lin_ch3_1",
    "point_id": "club_building",
    "time_slot": "after_school",
    "chapter": 3,
    "act": "波澜",
    "route": "lin",
    "day_range": [10, 14],
    "speaker": "苏逸",
    "text": "学生会长苏逸——一个温和的高三男生——在走廊拦住你。"你就是最近常帮林澄忙的那个转学生吧？"他笑了笑，"我下学期就毕业了，学生会的事都要交给她。她这个人，不到倒下都不会说累的。"",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch3_promise", "lin_ch3_aware"],
      "affection_at_least": {"lin": 6},
      "once": true
    },
    "choices": [
      {
        "text": "认真地答应苏逸",
        "affection_delta": {},
        "set_flags": ["lin_ch3_promise"],
        "mark_visited": true,
        "result_text": "苏逸拍了拍你的肩："拜托你了。"你觉得这份承诺沉甸甸的。",
        "advance_time": false
      },
      {
        "text": "说"她比你想的坚强，但我也会注意的"",
        "affection_delta": {"lin": 1},
        "set_flags": ["lin_ch3_aware"],
        "mark_visited": true,
        "result_text": "苏逸看了你一会儿，笑着说："看来她找到了靠得住的人。"",
        "advance_time": false
      }
    ]
  },
  {
    "id": "evt_lin_ch3_2",
    "point_id": "rooftop",
    "time_slot": "after_school",
    "chapter": 3,
    "act": "波澜",
    "route": "lin",
    "day_range": [12, 16],
    "speaker": "林澄",
    "text": "你想帮林澄分担文化祭的布展工作，来到天台。但她看到你后突然态度冷淡地说"你不用管，我自己能做。"然后把门关了。你站在天台门前，听到门里传来很轻的叹气声。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch3_waited", "lin_ch3_gave_space"],
      "affection_at_least": {"lin": 7},
      "flag_any": ["lin_ch3_promise", "lin_ch3_aware"],
      "once": true
    },
    "choices": [
      {
        "text": "在门外说"我就在这等你，不急"",
        "affection_delta": {"lin": 2},
        "set_flags": ["lin_ch3_waited"],
        "mark_visited": true,
        "result_text": "过了很久，门吱呀一声打开了。她没看你，但轻声说了句"……进来吧"。她的眼眶有点红。",
        "advance_time": true
      },
      {
        "text": "默默离开，给她空间",
        "affection_delta": {"lin": 0},
        "set_flags": ["lin_ch3_gave_space"],
        "mark_visited": true,
        "result_text": "你转身走下楼梯。走到一半，听到天台那边似乎有什么东西掉在地上的声音。",
        "advance_time": true
      }
    ]
  },
  {
    "id": "evt_lin_ch3_3",
    "point_id": "school_gate",
    "time_slot": "night",
    "chapter": 3,
    "act": "波澜",
    "route": "lin",
    "day_range": [14, 18],
    "speaker": "林澄",
    "text": "你在校门附近等了一会儿，发现林澄还没出校门。天已经很晚了。远处传来她和手机里的声音——像是在和姐姐通话，语气里有在你面前从未展现过的疲惫和委屈。"姐，我没事……真的没事……"",
    "conditions": {
      "required_flags": ["lin_ch3_waited"],
      "blocked_flags": ["lin_ch3_cocoa", "lin_ch3_pretend"],
      "affection_at_least": {"lin": 8},
      "once": true
    },
    "choices": [
      {
        "text": "等她挂了电话，递给她一罐热可可",
        "affection_delta": {"lin": 4},
        "set_flags": ["lin_ch3_cocoa"],
        "mark_visited": true,
        "result_text": "她接过去的手在微微发抖。很久之后她才开口："你怎么知道我在这……"声音里带着鼻音。",
        "advance_time": true
      },
      {
        "text": "装作刚到，若无其事地打招呼",
        "affection_delta": {"lin": 2},
        "set_flags": ["lin_ch3_pretend"],
        "mark_visited": true,
        "result_text": "她勉强笑了笑，把手机收起来。"你怎么还没走？"语气故作轻松，但眼角还是红的。",
        "advance_time": true
      }
    ]
  },
  {
    "id": "evt_lin_ch4_1",
    "point_id": "club_building",
    "time_slot": "after_school",
    "chapter": 4,
    "act": "破冰",
    "route": "lin",
    "day_range": [17, 22],
    "speaker": "林澄",
    "text": "文化祭开幕当天。学生会的展区出了问题——物资送错了。林澄咬着唇在电话里协调，声音在控制着不发抖。你看出她快到极限了。",
    "conditions": {
      "required_flags": [],
      "blocked_flags": ["lin_ch4_trust", "lin_ch4_silent_help"],
      "affection_at_least": {"lin": 10},
